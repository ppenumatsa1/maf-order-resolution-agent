APP_ENV=foundry-hosted
WORKFLOW_MODE=foundry_hosted
STORE_PROVIDER=app_db
RAG_PROVIDER=foundry_iq
MEMORY_PROVIDER=foundry_memory

# Foundry placeholders
# FOUNDRY_PROJECTS_ENDPOINT=https://<project>.services.ai.azure.com/api/projects/<project-name>
# FOUNDRY_MODEL_DEPLOYMENT_NAME=<deployment-name>
FOUNDRY_HOSTED_INVOCATIONS_URL=http://localhost:8001/invocations
FOUNDRY_HOSTED_PROTOCOL=invocations
# Optional: shadow Invocations user turns into Responses with synthetic=true
# metadata. This is for portal conversation/trace comparison only.
FOUNDRY_HOSTED_CONVERSATION_SHADOW_PROVIDER=none
# FOUNDRY_HOSTED_RESPONSES_URL=http://localhost:8001/responses
# FOUNDRY_HOSTED_RESPONSES_TIMEOUT_SECONDS=3
# FOUNDRY_HOSTED_API_KEY=<hosted-agent-api-key>
# FOUNDRY_EVENT_CALLBACK_TOKEN=<shared-token-for-/api/foundry/events>

# Foundry-hosted agent state/memory providers. These affect only the hosted
# agent package; local and Azure app-hosted MAF SDK workflows remain
# Postgres-backed through the backend.
FOUNDRY_HOSTED_STATE_PROVIDER=stateless_context
FOUNDRY_HOSTED_MEMORY_PROVIDER=none
# FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
# FOUNDRY_HOSTED_MODEL_DEPLOYMENT_NAME=<chat-model-deployment>
# FOUNDRY_HOSTED_EMBEDDINGS_DEPLOYMENT_NAME=<embedding-model-deployment>

# Foundry Memory Store is a preview feature. Enable it only after accepting the
# Azure preview terms and assigning the hosted agent identity access to the
# Foundry project.
# FOUNDRY_HOSTED_MEMORY_PROVIDER=foundry
# FOUNDRY_HOSTED_MEMORY_STORE_NAME=<memory-store-name>
# FOUNDRY_HOSTED_MEMORY_MODEL_DEPLOYMENT_NAME=<memory-chat-model-deployment>
# FOUNDRY_HOSTED_MEMORY_EMBEDDINGS_DEPLOYMENT_NAME=<memory-embedding-model-deployment>
# FOUNDRY_HOSTED_MEMORY_UPDATE_DELAY_SECONDS=300

# Foundry/Azure Monitor tracing
OTEL_SERVICE_NAME=maf-foundry-hosted-agent
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=false
APPLICATIONINSIGHTS_CONNECTION_STRING=
