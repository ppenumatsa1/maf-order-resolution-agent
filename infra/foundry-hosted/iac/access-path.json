            "value": "[parameters('bastionSubnetPrefix')]"
          },
          "runnerNsgName": {
            "value": "[parameters('runnerSubnetNsgName')]"
          },
          "createBastion": {
            "value": "[parameters('createBastionHost')]"
          },
          "createRunnerVm": {
            "value": "[parameters('createRunnerVm')]"
