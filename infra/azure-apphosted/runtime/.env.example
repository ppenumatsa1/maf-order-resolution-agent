APP_ENV=azure-apphosted
WORKFLOW_MODE=maf_sdk
STORE_PROVIDER=postgres
MEMORY_PROVIDER=postgres

# Azure PostgreSQL managed-identity path. The process obtains an Entra token for
# each physical Psycopg connection; do not set a password-based DATABASE_URL.
# AZURE_POSTGRES_HOST=<server>.postgres.database.azure.com
# AZURE_POSTGRES_DATABASE=maf_workflow
# AZURE_POSTGRES_USER=<backend-user-assigned-identity-name>
# AZURE_CLIENT_ID=<backend-user-assigned-identity-client-id>
# ENABLE_TELEMETRY=true
# ENABLE_INSTRUMENTATION=true
# OTEL_RECORD_CONTENT=false
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Azure AI Foundry app-hosted resources are provisioned by Bicep for model and
# evaluation use. These values are safe non-secret configuration.
# FOUNDRY_PROJECTS_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/order-resolution
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
# FOUNDRY_EMBEDDINGS_DEPLOYMENT_NAME=text-embedding-3-small
# Compatibility aliases only for existing developer environments:
# FOUNDRY_PROJECT_ENDPOINT, MAF_MODEL, FOUNDRY_MODEL, MAF_PROVIDER

# Optional MCP integration
# MCP_SERVER_URL=https://<mcp-host>/mcp
# MCP_API_KEY=<secret>
# MCP_BEARER_TOKEN=<secret>
