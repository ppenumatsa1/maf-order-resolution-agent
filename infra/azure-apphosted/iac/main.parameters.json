      "value": 50
    },
    "foundryEmbeddingsDeploymentName": {
      "value": "text-embedding-3-small"
    },
    "foundryEmbeddingsModelFormat": {
      "value": "OpenAI"
    },
    "foundryEmbeddingsModelName": {
      "value": "text-embedding-3-small"
    },
    "foundryEmbeddingsModelVersion": {
      "value": "1"
    },
    "foundryEmbeddingsDeploymentSkuName": {
      "value": "GlobalStandard"
    },
    "foundryEmbeddingsDeploymentCapacity": {
      "value": 1
    },
    "foundryEvaluatorDeploymentCapacity": {
      "value": 50
    },
    "foundryRaiPolicyName": {
      "value": "Microsoft.Default"
    }
  }
}
