            "runnerUamiName": {
              "type": "string",
              "defaultValue": "uami-maffnd-runner",
              "metadata": {
                "description": "Runner user-assigned managed identity name"
              }
            },
            "keepSystemAssignedIdentity": {
              "type": "bool",
              "defaultValue": false,
              "metadata": {
                "description": "Keep system-assigned identity on VM in addition to UAMI."
