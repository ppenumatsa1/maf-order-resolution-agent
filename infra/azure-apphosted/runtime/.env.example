APP_ENV=azure-apphosted
WORKFLOW_MODE=maf_sdk
STORE_PROVIDER=postgres
RAG_PROVIDER=pgvector
MEMORY_PROVIDER=postgres

# Azure PostgreSQL parity path. Keep STORE_PROVIDER=postgres until provider
# switching is implemented; Azure PostgreSQL is selected through DATABASE_URL.
# DATABASE_URL=postgresql://<user>:<password>@<server>.postgres.database.azure.com:5432/<db>?sslmode=require
# ENABLE_TELEMETRY=true
# ENABLE_INSTRUMENTATION=true
# OTEL_RECORD_CONTENT=false
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Azure AI Foundry app-hosted resources are provisioned by Bicep. The current
# workflow still uses pgvector by default; these values are for the model client
# integration path and are safe non-secret configuration.
# FOUNDRY_PROJECTS_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/order-resolution
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o-mini
# FOUNDRY_EMBEDDINGS_DEPLOYMENT_NAME=text-embedding-3-small
# Compatibility aliases only for existing developer environments:
# FOUNDRY_PROJECT_ENDPOINT, MAF_MODEL, FOUNDRY_MODEL, MAF_PROVIDER

# Optional future Azure AI Search provider. Current parity path uses pgvector.
# AZURE_AI_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
# AZURE_AI_SEARCH_KEY=<key>
# AZURE_AI_SEARCH_INDEX=policy-index

# Optional MCP integration
# MCP_SERVER_URL=https://<mcp-host>/mcp
# MCP_API_KEY=<secret>
# MCP_BEARER_TOKEN=<secret>
