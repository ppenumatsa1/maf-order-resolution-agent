APP_ENV=local
OTEL_SERVICE_NAME=maf-customer-resolution
# ENABLE_TELEMETRY=true
# ENABLE_INSTRUMENTATION=true
# OTEL_RECORD_CONTENT=false
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# Workflow Studio target switching (`make down && make up`) uses backend/.env.
# Keep one case active at a time:
# CASE 1 (Azure-hosted MAF): API_URL=https://<azure-backend-host> and WORKFLOW_MODE=maf_sdk
# CASE 2 (Foundry-hosted via local backend adapter): API_URL=http://localhost:8000,
#   WORKFLOW_MODE=foundry_hosted, FOUNDRY_HOSTED_INVOCATIONS_URL=https://<...>/invocations
#   If FOUNDRY_HOSTED_API_KEY is left empty, `make up` will try to use host `az` token.
# API_URL=http://localhost:8000
# WORKFLOW_MODE=maf_sdk
# Valid values: maf_sdk | foundry_hosted
# STORE_PROVIDER=postgres
# RAG_PROVIDER=pgvector  # pgvector | azure_ai_search | foundry_vector | foundry_iq
# MEMORY_PROVIDER=postgres  # postgres | foundry_memory
# MAF_ENV_FILE=.env

# MCP integration
# MCP_SERVER_URL=http://localhost:8011/mcp
# MCP_API_KEY=demo-api-key
# MCP_API_KEY_HEADER=X-API-Key
# MCP_BEARER_TOKEN=demo-bearer-token
# MCP_TIMEOUT_SECONDS=15

# Read-only retry guardrails
# READ_RETRY_ATTEMPTS=3
# READ_RETRY_DELAY_SECONDS=0.2

# Optional Azure AI Foundry model client. These are non-secret values; local
# and CI runs use deterministic triage when they are absent.
# FOUNDRY_PROJECTS_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/order-resolution
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
# Foundry-hosted invocation endpoint (required only when WORKFLOW_MODE=foundry_hosted):
# FOUNDRY_HOSTED_INVOCATIONS_URL=https://<hosted-agent-endpoint>/invocations
# Hosted agent package defaults to dual because agent.yaml declares both
# invocations and responses. Set invocations only for rollback builds.
# FOUNDRY_HOSTED_PROTOCOL=dual
# Optional hosted-agent conversation shadowing. When enabled, Invocations user
# turns are also posted to Responses with synthetic=true metadata for portal
# visibility; this does not switch backend/UI traffic to Responses.
# FOUNDRY_HOSTED_CONVERSATION_SHADOW_PROVIDER=none  # none | responses
# FOUNDRY_HOSTED_RESPONSES_URL=https://<hosted-agent-endpoint>/responses
# FOUNDRY_HOSTED_RESPONSES_TIMEOUT_SECONDS=3
# FOUNDRY_HOSTED_API_KEY=<api-key-if-required>
# FOUNDRY_HOSTED_TIMEOUT_SECONDS=30
# FOUNDRY_EVENT_CALLBACK_TOKEN=<shared-token-for-/api/foundry/events>
# Compatibility aliases only for existing developer environments:
# FOUNDRY_PROJECT_ENDPOINT, MAF_MODEL, FOUNDRY_MODEL, MAF_PROVIDER

# Mock MCP server settings (for scripts/mcp/mock_mcp_server.py)
# MOCK_MCP_API_KEY=demo-api-key
# MOCK_MCP_BEARER_TOKEN=demo-bearer-token
