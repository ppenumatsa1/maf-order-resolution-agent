{
  "required_event_types": [
    "workflow.stage",
    "tool.call",
    "checkpoint.created",
    "hitl.request",
    "hitl.response",
    "workflow.output"
  ],
  "cases": [
    {
      "id": "low-risk-no-hitl",
      "prompt": "Order ORD-1001 was late by one day.",
      "expect_hitl": false,
      "required_events": ["workflow.stage", "tool.call", "workflow.output"],
      "required_order": ["workflow.stage", "tool.call", "workflow.output"],
      "required_payload_fields": {
        "tool.call": ["order.order_id"],
        "workflow.output": ["status", "message"]
      },
      "forbidden_events": ["hitl.request", "checkpoint.created", "hitl.response"]
    },
    {
      "id": "high-risk-hitl-approve",
      "prompt": "Order ORD-1009 is delayed by 5 days. I need compensation.",
      "expect_hitl": true,
      "decision": "approve",
      "required_events": [
        "workflow.stage",
        "tool.call",
        "checkpoint.created",
        "hitl.request",
        "hitl.response",
        "workflow.output"
      ],
      "required_order": [
        "workflow.stage",
        "checkpoint.created",
        "hitl.request",
        "hitl.response",
        "workflow.output"
      ],
      "required_payload_fields": {
        "checkpoint.created": ["checkpoint_id"],
        "hitl.request": ["checkpoint_id", "order_id", "amount"],
        "hitl.response": ["checkpoint_id", "decision"],
        "workflow.output": ["status", "message"]
      },
      "forbidden_events": []
    }
  ]
}
