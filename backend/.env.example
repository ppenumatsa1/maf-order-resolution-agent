APP_ENV=local
OTEL_SERVICE_NAME=maf-customer-resolution
# ENABLE_TELEMETRY=true
# ENABLE_INSTRUMENTATION=true
# OTEL_RECORD_CONTENT=false
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# Local Compose defaults to the shared MAF workflow path. Set
# RUNTIME_TARGET=responses_wrapper only when FOUNDRY_RESPONSES_ENDPOINT targets
# a deployed Responses endpoint; browser traffic remains same-origin.
# RUNTIME_TARGET=local_maf
# FOUNDRY_RESPONSES_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/order-resolution/agents/order-resolution-hosted/endpoint/protocols/openai/responses?api-version=v1
# FOUNDRY_RESPONSES_TIMEOUT_SECONDS=60
# API_URL=http://localhost:8000
# STORE_PROVIDER=postgres
# RAG_PROVIDER=pgvector  # pgvector | azure_ai_search | foundry_vector | foundry_iq
# MEMORY_PROVIDER=postgres  # postgres | foundry_memory
# MAF_ENV_FILE=.env

# MCP integration
# MCP_SERVER_URL=http://localhost:8011/mcp
# MCP_API_KEY=demo-api-key
# MCP_API_KEY_HEADER=X-API-Key
# MCP_BEARER_TOKEN=demo-bearer-token
# MCP_TIMEOUT_SECONDS=15

# Read-only retry guardrails
# READ_RETRY_ATTEMPTS=3
# READ_RETRY_DELAY_SECONDS=0.2

# Optional Azure AI Foundry model client. These are non-secret values; local
# and CI runs use deterministic triage when they are absent.
# FOUNDRY_PROJECTS_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/order-resolution
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
# Compatibility aliases only for existing developer environments:
# FOUNDRY_PROJECT_ENDPOINT, MAF_MODEL, FOUNDRY_MODEL, MAF_PROVIDER

# Mock MCP server settings (for scripts/mcp/mock_mcp_server.py)
# MOCK_MCP_API_KEY=demo-api-key
# MOCK_MCP_BEARER_TOKEN=demo-bearer-token
