              "value": "[if(and(and(parameters('enabled'), parameters('createRunnerVm')), parameters('createRunnerUami')), reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('runnerUamiName')), '2023-01-31').principalId, '')]"
            },
            "runnerUamiClientId": {
              "type": "string",
              "value": "[if(and(and(parameters('enabled'), parameters('createRunnerVm')), parameters('createRunnerUami')), reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('runnerUamiName')), '2023-01-31').clientId, '')]"
